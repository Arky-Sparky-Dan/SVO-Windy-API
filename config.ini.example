# allsky_windy configuration
# Copy this file to config.ini and fill in your credentials.
# config.ini is in .gitignore so passwords are never committed.

[allsky]
# Full path to the image AllSky overwrites on every capture.
# AllskyTeam/allsky default on Raspberry Pi:
image_path = /home/pi/allsky/tmp/image.jpg

[ftp]
# Hostinger FTP credentials — find these in hPanel → FTP Accounts
host     = files.hostinger.com
username = YOUR_FTP_USERNAME
password = YOUR_FTP_PASSWORD

# Path on the server (relative to FTP root, which is usually public_html)
remote_path = public_html/allsky/Current.jpg

# How often to upload a fresh image (seconds). 60 = once per minute.
upload_interval_seconds = 60

# FTP connection timeout in seconds
timeout_seconds = 30

[windy]
# Your Windy.com API key
api_key = YOUR_WINDY_API_KEY

# Upload endpoint — to be filled in once Windy confirms the URL.
# Leave blank until then; the script will skip the Windy POST step.
upload_endpoint =

# Set to true to enable Windy POST uploads (requires upload_endpoint above)
enabled = false

[logging]
# Log verbosity: DEBUG, INFO, WARNING, ERROR
level = INFO

# Optional log file. Leave blank to log to stdout only.
# log_file = /home/pi/allsky_windy.log
log_file =
