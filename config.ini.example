# allsky_windy configuration
# Copy this file to config.ini and edit the image_path for your system.
# This script is optional — it only monitors image freshness.
# Windy.com pulls directly from https://svo.space/allsky/Current.jpg

[allsky]
# Path to the image AllSky overwrites on every capture.
#
# Windows:
image_path = C:\allsky\tmp\image.jpg
#
# Linux / Raspberry Pi:
# image_path = /home/pi/allsky/tmp/image.jpg

# Warn if the image hasn't updated in this many seconds (default: 120)
stale_threshold_seconds = 120

[logging]
# DEBUG / INFO / WARNING / ERROR
level = INFO

# Log file path — recommended on Windows so you can review it easily.
# Windows:
log_file = C:\allsky-windy\allsky_windy.log
# Linux:
# log_file = /home/pi/allsky_windy.log
# Leave blank to log to console only:
# log_file =
