# Upload this file to the /allsky/ directory on Hostinger via FTP or File Manager.
# It tells browsers and CDNs to treat Current.jpg as fresh after 30 seconds,
# so Windy.com always gets the latest frame rather than a cached copy.

<Files "Current.jpg">
    Header set Cache-Control "public, max-age=30, must-revalidate"
    Header unset Pragma
</Files>
