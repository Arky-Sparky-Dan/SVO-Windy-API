<?xml version="1.0" encoding="UTF-16"?>
<!--
  Windows Task Scheduler definition for allsky_windy.py

  Import via Task Scheduler UI:
    1. Open Task Scheduler (search "Task Scheduler" in Start menu)
    2. Action → Import Task...
    3. Select this file
    4. Review settings and click OK

  Or import via command line (run as Administrator):
    schtasks /create /xml "allsky-windy-task.xml" /tn "AllSky-Windy-Uploader"

  IMPORTANT: Edit the <Command> and <WorkingDirectory> paths below to match
  where you installed the script before importing.
-->
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Uploads AllSky camera image to Hostinger/Windy.com every 60 seconds</Description>
    <Author>SVO Observatory</Author>
  </RegistrationInfo>
  <Triggers>
    <BootTrigger>
      <Enabled>true</Enabled>
    </BootTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <RestartOnFailure>
      <Interval>PT1M</Interval>
      <Count>999</Count>
    </RestartOnFailure>
    <Enabled>true</Enabled>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <!-- EDIT THESE TWO PATHS before importing -->
      <Command>C:\Python312\python.exe</Command>
      <Arguments>C:\allsky-windy\allsky_windy.py --config C:\allsky-windy\config.ini</Arguments>
      <WorkingDirectory>C:\allsky-windy</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
